{
  "name": "@kenotron-ms/amplifier-core",
  "version": "1.3.4",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "test": "vitest run"
  },
  "napi": {
    "name": "amplifier-core",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "optionalDependencies": {
    "@kenotron-ms/amplifier-core-darwin-arm64": "1.3.4",
    "@kenotron-ms/amplifier-core-darwin-x64": "1.3.4",
    "@kenotron-ms/amplifier-core-linux-arm64-gnu": "1.3.4",
    "@kenotron-ms/amplifier-core-linux-x64-gnu": "1.3.4",
    "@kenotron-ms/amplifier-core-win32-x64-msvc": "1.3.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "vitest": "^3",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kenotron-ms/amplifier-core"
  }
}
