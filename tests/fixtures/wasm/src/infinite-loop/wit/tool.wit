// Minimal WIT for tool-module world.
// Extracted from the main amplifier-modules.wit to avoid pulling in
// WASI HTTP dependencies that are only needed by the provider-module world.

package amplifier:modules@1.0.0;

/// Tool module interface — exposes a single tool to the kernel.
interface tool {
    /// Return the tool specification (ToolSpec proto, serialized).
    get-spec: func() -> list<u8>;

    /// Execute the tool with proto-serialized input (ToolExecuteRequest).
    /// Returns proto-serialized ToolExecuteResponse on success.
    execute: func(input: list<u8>) -> result<list<u8>, string>;
}

/// Tier 1: Pure-compute tool module.
world tool-module {
    export tool;
}
